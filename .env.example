# Local SQLite database used by Prisma.
DATABASE_URL="file:./dev.db"

# Auth.js / NextAuth.
AUTH_SECRET="your-auth-secret-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth is optional. Leave these empty to hide Google login locally.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
NEXT_PUBLIC_GOOGLE_ENABLED="false"

# Anthropic is optional for local testing. The app uses demo responses until
# this is replaced with a real key.
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Public app URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
